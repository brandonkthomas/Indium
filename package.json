{
  "name": "@indium/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./build/indium.js",
    "./css": "./build/indium.css",
    "./components/dialogs": "./build/components/dialogs.js",
    "./components/glassSurface": "./build/components/glassSurface.js",
    "./components/infiniteScroll": "./build/components/infiniteScroll.js",
    "./components/popupMenu": "./build/components/popupMenu.js",
    "./components/sidebar": "./build/components/sidebar.js",
    "./components/gradNoiseCanvas": "./build/components/gradNoiseCanvas.js",
    "./components/navbar": "./build/components/navbar.js",
    "./components/dialogs.css": "./build/components/dialogs.css",
    "./components/glassSurface.css": "./build/components/glassSurface.css",
    "./components/infiniteScroll.css": "./build/components/infiniteScroll.css",
    "./components/popupMenu.css": "./build/components/popupMenu.css",
    "./components/sidebar.css": "./build/components/sidebar.css",
    "./components/cards.css": "./build/components/cards.css",
    "./components/navbar.css": "./build/components/navbar.css",
    "./components/shell.css": "./build/components/shell.css"
  },
  "scripts": {
    "clean": "rm -rf build/indium.js build/indium.css build/components",
    "build:js": "node scripts/build.mjs js",
    "build:css": "node scripts/build.mjs css",
    "build": "npm run clean && npm run build:js && npm run build:css",
    "check": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
