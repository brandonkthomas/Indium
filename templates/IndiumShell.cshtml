@* Minimal host shell scaffold for Indium UI kit integration *@
<section class="wa-app" data-wa-app>
    <div class="wa-shell">
        <header class="wa-topbar" aria-label="Indium navigation">
            <div class="wa-topbar__inner">
                <div class="wa-topbar__left">
                    <button class="wa-iconbtn wa-topbar__burger" type="button" data-wa-sidebar-toggle aria-label="Open navigation">
                        Menu
                    </button>
                    <div class="wa-topbar__titleblock">
                        <div class="wa-topbar__title">Indium</div>
                    </div>
                </div>
            </div>
        </header>

        <aside class="wa-sidebar" data-wa-sidebar aria-label="Navigation">
            <button class="wa-sidebar__close" type="button" data-wa-sidebar-close aria-label="Close navigation">Close</button>
            <nav class="wa-sidenav" aria-label="Primary navigation">
                <a class="wa-sidenav__link" href="#" data-wa-nav="home">Home</a>
                <a class="wa-sidenav__link" href="#" data-wa-nav="library">Library</a>
            </nav>
        </aside>

        <main class="wa-content" data-wa-view-host></main>
    </div>

    <div class="wa-sidebar-overlay" data-wa-sidebar-overlay aria-hidden="true"></div>
</section>
